{
  "name": "path-terminal-init",
  "version": "0.1.0",
  "description": "One-line setup for the Path Terminal SDK integration assistant — configures MCP server, Cursor rules, and optionally adds the SDK to your Xcode project.",
  "bin": {
    "path-terminal-init": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "rules"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "path",
    "terminal",
    "sdk",
    "payment",
    "mcp",
    "cursor",
    "ios",
    "swift"
  ]
}
